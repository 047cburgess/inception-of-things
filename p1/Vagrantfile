# -*- mode: ruby -*-
# vi: set ft=ruby :
#

Vagrant.configure("2") do |config|

  config.vm.box = "generic/debian12"


  # SERVER
  config.vm.define "caburgesS" do |server|
    server.vm.hostname = "caburgesS"
    server.vm.network "private_network", ip: "192.168.56.110"
    server.vm.provider "virtualbox" do |v|
      v.customize ["modifyvm", :id, "--name", "caburgesS"]
      v.memory = 1024
      v.cpus = 1
    end
    server.vm.provision "shell", path: "scripts/install-k3s-server.sh"
  end

  #TODO set provider virtualbox, use minimumus from subject, and set virtualization 
  #TODO install k3s


  # SERVER WORKER
  config.vm.define "caburgesSW" do |worker|
    worker.vm.hostname = "caburgesSW"
    worker.vm.network "private_network", ip: "192.168.56.111"
    worker.vm.provider "virtualbox" do |v|
      v.customize ["modifyvm", :id, "--name", "caburgesSW"]
      v.memory = 1024
      v.cpus = 1
    end
    worker.vm.provision "shell", path: "scripts/install-k3s-worker.sh"
  end


end

