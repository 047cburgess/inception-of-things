# -*- mode: ruby -*-
# vi: set ft=ruby :
#

require 'securerandom'

VM = {
  'SERVER' => {
    name: 'caburgesS',
    ip: '192.168.56.110'
  },
  'WORKER' => {
    name: 'caburgesSW',
    ip: '192.168.56.111'
  }
}

agent_token = SecureRandom.hex(32)

Vagrant.configure("2") do |config|

  config.vm.box = "bento/debian-13"

  # SERVER
  config.vm.define VM['SERVER'][:name] do |server|
    server.vm.hostname = VM['SERVER'][:name]
    server.vm.network :forwarded_port, guest: 80, host: 8888
    server.vm.network "private_network", ip: VM['SERVER'][:ip]
    server.vm.provider "virtualbox" do |v|
      v.name = VM['SERVER'][:name]
      v.memory = 1024
      v.cpus = 2
    end
    server.vm.provision "Install k3s", type: "shell", path: "scripts/install-k3s-server.sh", env: {"K3S_TOKEN" => agent_token}
  end

  # SERVER WORKER
  config.vm.define VM['WORKER'][:name] do |worker|
    worker.vm.hostname = VM['WORKER'][:name]
    worker.vm.network "private_network", ip: VM['WORKER'][:ip]
    worker.vm.provider "virtualbox" do |v|
      v.name = VM['WORKER'][:name]
      v.memory = 1024
      v.cpus = 2
    end
    worker.vm.provision "Install k3s", type: "shell", path: "scripts/install-k3s-worker.sh", env: {"K3S_TOKEN" => agent_token}

    # Show k3s nodes and welcome message
    worker.trigger.after [:up] do |trigger|
      trigger.ruby do |env, machine|
        system("bash scripts/after.sh")
      end
    end

  end

end
