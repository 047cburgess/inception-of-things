# -*- mode: ruby -*-
# vi: set ft=ruby :
#

VM = {
  'SERVER' => {
    name: 'caburgesS',
    ip: '192.168.56.110'
  },
  'WORKER' => {
    name: 'caburgesSW',
    ip: '192.168.56.111'
  }
}


Vagrant.configure("2") do |config|

  config.vm.box = "generic/debian12"

  # SERVER
  config.vm.define VM['SERVER'][:name] do |server|
    server.vm.hostname = VM['SERVER'][:name]
    server.vm.network "private_network", ip: VM['SERVER'][:ip]
    server.vm.provider "virtualbox" do |v|
      v.name = VM['SERVER'][:name]
      v.memory = 1024
      v.cpus = 2
    end
    server.vm.provision "shell", path: "scripts/install-k3s-server.sh"
    server.vm.synced_folder "/home/vagrant/shared", "/token", create: true
  end

  # SERVER WORKER
  config.vm.define VM['WORKER'][:name] do |worker|
    worker.vm.hostname = VM['WORKER'][:name]
    worker.vm.network "private_network", ip: VM['WORKER'][:ip]
    worker.vm.provider "virtualbox" do |v|
      v.name = VM['WORKER'][:name]
      v.memory = 1024
      v.cpus = 2
    end
    worker.vm.provision "shell", path: "scripts/install-k3s-worker.sh"
    worker.vm.synced_folder "/home/vagrant/shared", "/token", create: true
  end

  config.trigger.after :up do |trigger|
    trigger.info = "Showing k3s nodes..."
    trigger.run = { inline: "vagrant ssh caburgesS -c 'kubectl get nodes -o wide'"}
  end

end
